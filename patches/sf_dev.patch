From: Niklas Fiekas <niklas.fiekas@backscattering.de>
Date: Tue, 9 Jun 2026 22:13:56 +0200
Subject: [PATCH] stockfish-web patch

Co-authored-by: Jonathan Gamble <gamblej@gmail.com>
---
 src/engine.h         |  7 +++++++
 src/main.cpp         |  8 +++++++-
 src/misc.cpp         |  3 ++-
 src/nnue/network.cpp | 13 +++++++++++++
 src/nnue/network.h   |  1 +
 src/timeman.h        |  2 +-
 src/uci.cpp          |  4 ++++
 src/uci.h            |  3 ++-
 8 files changed, 37 insertions(+), 4 deletions(-)

diff --git a/src/engine.h b/src/engine.h
index 52c14e97..2d91f6ff 100644
--- a/src/engine.h
+++ b/src/engine.h
@@ -94,6 +94,13 @@ class Engine {
     void                                 load_network(const std::filesystem::path& file);
     void save_network(const std::optional<std::filesystem::path>& file);
 
+    void load_big_network(std::istream& is) {
+        network.modify_and_replicate(
+          [this, &is](Eval::NNUE::Network& network_) { network_.load_stream(is, networkFile); });
+        threads.clear();
+        threads.ensure_network_replicated();
+    }
+
     // utility functions
 
     void trace_eval() const;
diff --git a/src/main.cpp b/src/main.cpp
index 7e36b23d..fba339a8 100644
--- a/src/main.cpp
+++ b/src/main.cpp
@@ -29,6 +29,8 @@
 
 using namespace Stockfish;
 
+UCIEngine* uci_global;
+
 #ifdef UNIVERSAL_BINARY
 namespace Stockfish {
 
@@ -44,13 +46,17 @@ int main(int argc, char* argv[]) {
     Attacks::init();
     Position::init();
 
-    auto cli = CommandLine(argc, argv);
+    auto cli = CommandLine(0, {});
     auto uci = std::make_unique<UCIEngine>(std::move(cli));
 
+    uci_global = uci.get();
+
     Tune::init(uci->engine_options());
 
     uci->loop();
 
+    uci_global = nullptr;
+
     return 0;
 }
 
diff --git a/src/misc.cpp b/src/misc.cpp
index 64f67cff..93a45480 100644
--- a/src/misc.cpp
+++ b/src/misc.cpp
@@ -571,6 +571,7 @@ bool is_whitespace(std::string_view s) {
 }
 
 fs::path CommandLine::get_binary_directory(fs::path argv0) {
+    return fs::path{};
 
 #ifdef _WIN32
     #ifdef _MSC_VER
@@ -587,7 +588,7 @@ fs::path CommandLine::get_binary_directory(fs::path argv0) {
     return binaryDirectory;
 }
 
-fs::path CommandLine::get_working_directory() { return std::filesystem::current_path(); }
+fs::path CommandLine::get_working_directory() { return fs::path{}; }
 
 void set_console_utf8() {
 #ifdef _WIN32
diff --git a/src/nnue/network.cpp b/src/nnue/network.cpp
index 9e939eb9..7a2feb39 100644
--- a/src/nnue/network.cpp
+++ b/src/nnue/network.cpp
@@ -160,6 +160,8 @@ NetworkOutput Network::evaluate(const Position&    pos,
 void Network::verify(const std::function<void(std::string_view)>& f,
                      const EvalFile&                              evalFile,
                      fs::path                                     evalfilePath) const {
+    return; // Yep
+
     if (evalfilePath.empty())
         evalfilePath = evalFile.defaultName;
 
@@ -239,6 +241,17 @@ void Network::load_external(const fs::path& dir, const fs::path& evalfilePath, E
 }
 
 
+void Network::load_stream(std::istream& stream, EvalFile& evalFile) {
+    auto description = load(stream);
+
+    if (description.has_value())
+    {
+        evalFile.current        = fs::path{};
+        evalFile.netDescription = description.value();
+    }
+}
+
+
 void Network::load_internal(EvalFile& evalFile) {
     // C++ way to prepare a buffer for a memory stream
     class MemoryBuffer: public std::basic_streambuf<char> {
diff --git a/src/nnue/network.h b/src/nnue/network.h
index 4bcae527..dd7752f4 100644
--- a/src/nnue/network.h
+++ b/src/nnue/network.h
@@ -79,6 +79,7 @@ class Network {
                                  AccumulatorCaches& cache) const;
 
     void load_external(const std::filesystem::path&, const std::filesystem::path&, EvalFile&);
+    void load_stream(std::istream&, EvalFile&);
     void load_internal(EvalFile&);
 
    private:
diff --git a/src/timeman.h b/src/timeman.h
index 4439f84c..a2aa08e8 100644
--- a/src/timeman.h
+++ b/src/timeman.h
@@ -47,7 +47,7 @@ class TimeManagement {
     TimePoint elapsed(FUNC nodes) const {
         return useNodesTime ? TimePoint(nodes()) : elapsed_time();
     }
-    TimePoint elapsed_time() const { return now() - startTime; };
+    TimePoint elapsed_time() const { return std::max(now() - startTime, TimePoint(1)); };
 
     void clear();
     void advance_nodes_time(i64 nodes);
diff --git a/src/uci.cpp b/src/uci.cpp
index 2e35fe6d..2d732bde 100644
--- a/src/uci.cpp
+++ b/src/uci.cpp
@@ -41,6 +41,8 @@
 #include "types.h"
 #include "ucioption.h"
 
+std::string js_getline();  // src/dualnet-glue.cpp
+
 namespace Stockfish {
 
 constexpr auto BenchmarkCommand = "speedtest";
@@ -99,7 +101,9 @@ void UCIEngine::loop() {
             && !getline(std::cin, cmd))  // Wait for an input or an end-of-file (EOF) indication
             cmd = "quit";
 
+        cmd = js_getline();
         currentCmd = cmd;
+
         std::istringstream is(cmd);
 
         token.clear();  // Avoid a stale if getline() returns nothing or a blank line
diff --git a/src/uci.h b/src/uci.h
index 4d3c4cbb..c6b77e32 100644
--- a/src/uci.h
+++ b/src/uci.h
@@ -55,8 +55,9 @@ class UCIEngine {
 
     auto& engine_options() { return engine.get_options(); }
 
-   private:
     Engine      engine;
+
+   private:
     CommandLine cli;
     std::string currentCmd;
 
