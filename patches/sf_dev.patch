From 3b82a9f5550a2afa43bb97b50e972f900c6799ed Mon Sep 17 00:00:00 2001
From: Niklas Fiekas <niklas.fiekas@backscattering.de>
Date: Tue, 9 Jun 2026 22:13:56 +0200
Subject: [PATCH] stockfish-web patch

Co-authored-by: Jonathan Gamble <gamblej@gmail.com>
---
 src/engine.h         |  7 +++++++
 src/main.cpp         | 11 ++++++++---
 src/misc.cpp         |  2 ++
 src/nnue/network.cpp |  3 +++
 src/nnue/network.h   |  5 +++--
 src/timeman.h        |  2 +-
 src/uci.cpp          | 10 +++++++---
 src/uci.h            |  3 ++-
 8 files changed, 33 insertions(+), 10 deletions(-)

diff --git a/src/engine.h b/src/engine.h
index be9226a7..8c5bddf6 100644
--- a/src/engine.h
+++ b/src/engine.h
@@ -91,6 +91,13 @@ class Engine {
     void                                 load_network(const std::string& file);
     void save_network(std::pair<std::optional<std::string>, std::string> file);
 
+    void load_big_network(std::istream& is) {
+        network.modify_and_replicate(
+          [this, &is](Eval::NNUE::Network& network_) { network_.load(is); });
+        threads.clear();
+        threads.ensure_network_replicated();
+    }
+
     // utility functions
 
     void trace_eval() const;
diff --git a/src/main.cpp b/src/main.cpp
index c386c418..ea9bf686 100644
--- a/src/main.cpp
+++ b/src/main.cpp
@@ -28,6 +28,8 @@
 
 using namespace Stockfish;
 
+UCIEngine* uci_global;
+
 #ifdef UNIVERSAL_BINARY
 namespace Stockfish {
 
@@ -43,11 +45,14 @@ int main(int argc, char* argv[]) {
     Attacks::init();
     Position::init();
 
-    auto uci = std::make_unique<UCIEngine>(argc, argv);
+    uci_global = new UCIEngine(0, nullptr);
 
-    Tune::init(uci->engine_options());
+    Tune::init(uci_global->engine_options());
 
-    uci->loop();
+    uci_global->loop();
+
+    delete uci_global;
+    uci_global = nullptr;
 
     return 0;
 }
diff --git a/src/misc.cpp b/src/misc.cpp
index 4e7b912a..4216209d 100644
--- a/src/misc.cpp
+++ b/src/misc.cpp
@@ -508,6 +508,7 @@ bool is_whitespace(std::string_view s) {
 }
 
 std::string CommandLine::get_binary_directory(std::string argv0) {
+    return "";
     std::string pathSeparator;
 
 #ifdef _WIN32
@@ -542,6 +543,7 @@ std::string CommandLine::get_binary_directory(std::string argv0) {
 }
 
 std::string CommandLine::get_working_directory() {
+    return "";
     std::string workingDirectory = "";
     char        buff[40000];
     char*       cwd = GETCWD(buff, 40000);
diff --git a/src/nnue/network.cpp b/src/nnue/network.cpp
index 20149c73..42fc7da8 100644
--- a/src/nnue/network.cpp
+++ b/src/nnue/network.cpp
@@ -160,6 +160,9 @@ NetworkOutput Network::evaluate(const Position&    pos,
 
 void Network::verify(std::string                                  evalfilePath,
                      const std::function<void(std::string_view)>& f) const {
+
+    return; // Yep
+
     if (evalfilePath.empty())
         evalfilePath = evalFile.defaultName;
 
diff --git a/src/nnue/network.h b/src/nnue/network.h
index 4a17501f..44f89b66 100644
--- a/src/nnue/network.h
+++ b/src/nnue/network.h
@@ -73,14 +73,15 @@ class Network {
                                  AccumulatorStack&  accumulatorStack,
                                  AccumulatorCaches& cache) const;
 
+    std::optional<std::string> load(std::istream&);
+
    private:
     void load_user_net(const std::string&, const std::string&);
     void load_internal();
 
     void initialize();
 
-    bool                       save(std::ostream&, const std::string&, const std::string&) const;
-    std::optional<std::string> load(std::istream&);
+    bool save(std::ostream&, const std::string&, const std::string&) const;
 
     bool read_header(std::istream&, u32*, std::string*) const;
     bool write_header(std::ostream&, u32, const std::string&) const;
diff --git a/src/timeman.h b/src/timeman.h
index 4439f84c..a2aa08e8 100644
--- a/src/timeman.h
+++ b/src/timeman.h
@@ -47,7 +47,7 @@ class TimeManagement {
     TimePoint elapsed(FUNC nodes) const {
         return useNodesTime ? TimePoint(nodes()) : elapsed_time();
     }
-    TimePoint elapsed_time() const { return now() - startTime; };
+    TimePoint elapsed_time() const { return std::max(now() - startTime, TimePoint(1)); };
 
     void clear();
     void advance_nodes_time(i64 nodes);
diff --git a/src/uci.cpp b/src/uci.cpp
index 39268b05..227a5eaa 100644
--- a/src/uci.cpp
+++ b/src/uci.cpp
@@ -39,6 +39,8 @@
 #include "types.h"
 #include "ucioption.h"
 
+std::string js_getline();  // src/dualnet-glue.cpp
+
 namespace Stockfish {
 
 constexpr auto BenchmarkCommand = "speedtest";
@@ -64,8 +66,8 @@ void UCIEngine::print_info_string(std::string_view str) {
 }
 
 UCIEngine::UCIEngine(int argc, char** argv) :
-    engine(argv[0]),
-    cli(argc, argv) {
+    engine(),
+    cli(0, nullptr) {
 
     engine.get_options().add_info_listener([](const std::optional<std::string>& str) {
         if (str.has_value())
@@ -96,6 +98,8 @@ void UCIEngine::loop() {
             && !getline(std::cin, cmd))  // Wait for an input or an end-of-file (EOF) indication
             cmd = "quit";
 
+        cmd = js_getline();
+
         std::istringstream is(cmd);
 
         token.clear();  // Avoid a stale if getline() returns nothing or a blank line
@@ -171,7 +175,7 @@ void UCIEngine::loop() {
             sync_cout << "Unknown command: '" << cmd << "'. Type help for more information."
                       << sync_endl;
 
-    } while (token != "quit" && cli.argc == 1);  // The command-line arguments are one-shot
+    } while (token != "quit");  // The command-line arguments are one-shot
 }
 
 Search::LimitsType UCIEngine::parse_limits(std::istream& is) {
diff --git a/src/uci.h b/src/uci.h
index 6c3186ff..07f638db 100644
--- a/src/uci.h
+++ b/src/uci.h
@@ -55,8 +55,9 @@ class UCIEngine {
 
     auto& engine_options() { return engine.get_options(); }
 
-   private:
     Engine      engine;
+
+   private:
     CommandLine cli;
 
     static void print_info_string(std::string_view str);
